# Blockchain (Polygon Mainnet)
# Chain ID 137 = Polygon mainnet
NEXT_PUBLIC_CHAIN_ID=137
# Set this to the contract address after running: npm run deploy:polygon
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Your deployer wallet private key (never commit the real value)
PRIVATE_KEY=

# Optional: Alchemy/Infura RPC URL for Polygon (falls back to public RPC if omitted)
POLYGON_RPC_URL=

# Supabase (local)
# Get these from: `supabase status` (requires Docker running)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
